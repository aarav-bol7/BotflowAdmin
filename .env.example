# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Auth backend
VITE_API_BASE_URL=https://testing1.bol7.com/auth2

# DynamicADK (chat / analytics / notifications backend)
VITE_DYNAMICADK_BASE_URL=http://localhost:8000

# Credit service
VITE_CREDIT_SERVICE_BASE_URL=https://testing1.bol7.com/credit
VITE_CREDIT_BASE_URL=https://testing1.bol7.com/credit

# Cloudflare Turnstile (optional — OTP still sends without it)
VITE_TURNSTILE_SITE_KEY=

# Token-expiry watcher poll interval (seconds)
VITE_TOKEN_CHECK_INTERVAL=60

# X-Dashboard-Type sent to the auth backend on every request.
# Backend rejects accounts whose role isn't permitted for this dashboard.
# `client` = log in with a client-role account; `admin` = admin-role account.
VITE_DASHBOARD_TYPE=admin

# LiteLLM gateway — used by MultiLLM Chat page (src/pages/MultiLLMChat.jsx).
# Base URL is rewritten through Vite's dev proxy in development; in production
# the deployed admin host must either proxy /litellm/* or LiteLLM must allow
# the admin origin in its CORS allowlist.
VITE_LITELLM_BASE_URL=https://testing1.bol7.com/litellm
VITE_LITELLM_TOKEN=
